# Secrets — never commit these
client_secret.json
token.json
.env

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Runtime artifacts
/tmp/
*.log

# Dev sandbox output (not published, just for local UI iteration)
docs/dev_preview.html
docs/dev_preview-meta.json
fixtures/last_run_candidates.json

# Bot-generated artifacts — built fresh each workflow run, not committed to main.
# docs/*.html is rebuilt by main.py and uploaded as a Pages artifact.
# events_state.json (the per-message extraction cache) lives on the `state`
# branch, synced by the workflow.
# future_events.json is retired (see events_state.json); its last copy on the
# state branch is still restored once to bootstrap the cache.
# ignored_events.json is fetched fresh from Apps Script each run.
# .filter_audit.json is a local-only audit stamp.
# prior_events.json (the NEW-badge diff manifest, #13) lives on the `state`
# branch alongside events_state.json; restored/saved by the workflow.
docs/index.html
future_events.json
events_state.json
ignored_events.json
prior_events.json
.filter_audit.json
blocklist_auto.txt
blocklist_auto_audit.jsonl

# OS
.DS_Store

# IDEs
.idea/

# Soft-delete holding pen — the repo sits on a FUSE mount that refuses
# unlink, so agents `mv` files here instead of `rm`-ing them. Tom empties
# the folder periodically. The folder is not tracked; agents `mkdir -p`
# it on demand before each move. See design/soft-delete-convention.md.
.to_delete/